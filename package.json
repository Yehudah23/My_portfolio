{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "myportfolio",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --proxy-config proxy.conf.json",
    "start:proxy": "ng serve --proxy-config proxy.conf.json",
    "php": "php -S localhost:8000 -t php",
    "build": "npm run set-backend-url && ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:Myportfolio": "node dist/Myportfolio/server/server.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^21.2.6",
    "@angular/compiler": "^21.2.6",
    "@angular/core": "^21.2.6",
    "@angular/forms": "^21.2.6",
    "@angular/platform-browser": "^21.2.6",
    "@angular/platform-server": "^21.2.6",
    "@angular/router": "^21.2.6",
    "@angular/ssr": "^21.2.4",
    "@popperjs/core": "^2.11.8",
    "aos": "^2.3.4",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.10.5",
    "express": "^5.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.4",
    "@angular/cli": "^21.2.4",
    "@angular/compiler-cli": "^21.2.6",
    "@types/aos": "^3.0.7",
    "@types/bootstrap": "^5.2.10",
    "@types/express": "^5.0.1",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^20.17.19",
    "jasmine-core": "~5.7.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.9.3"
  },
  "overrides": {
    "rimraf": "^6.0.0",
    "glob": "^11.0.0",
    "inflight": "npm:@npmcli/fs@^4.0.0"
  }
